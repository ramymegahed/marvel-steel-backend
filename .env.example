# ============================================================
# Marvel Steel — Root Environment Variables
# Place this file at: marvel_steel/.env  (next to docker-compose.yml)
# NEVER commit this file to git — it's already in .gitignore
# ============================================================

# ── PostgreSQL Database ───────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=marvel_steel

# ── Backend (FastAPI) ─────────────────────────────────────────
# Generate a strong random key:  openssl rand -hex 32
SECRET_KEY=replace_with_a_long_random_secret_key_min_32_chars

# ── Telegram Notifications (optional) ────────────────────────
# Leave blank if not using Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Frontend (Vite) ───────────────────────────────────────────
# This URL is baked into the frontend bundle at BUILD TIME.
# It must be the public-facing URL/IP of the backend.
#
# Local Docker testing (backend on host port 8000):
#   VITE_API_URL=http://localhost:8000
#
# VPS / Contabo (replace with your server's public IP or domain):
#   VITE_API_URL=http://YOUR_VPS_IP:8000
#   VITE_API_URL=https://api.yourdomain.com
#
VITE_API_URL=http://localhost:8000
